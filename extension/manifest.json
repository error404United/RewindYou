{
  "manifest_version": 3,
  "name": "RewindYou - Web Content Extractor",
  "version": "1.0",
  "description": "Extract webpage content and metadata, then send to backend for storage",
  "permissions": ["scripting", "activeTab", "tabs", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
  },
  "options_page": "options.html",
  "host_permissions": ["<all_urls>"],
  "icons": {
  "16": "icons/icon16.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
  }
}